# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local or any file containing actual credentials

# Hugging Face API Token (Optional)
# Get your token at: https://huggingface.co/settings/tokens
# - Create a "Read" token (not Write)
# - Required for snapshot download method
# - NOT required for API method (USE_API=true) with public datasets
# - Token permissions: Read access to datasets
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Force Dataset Download (Optional)
# Set to "true" to force re-download of the dataset even if files exist
# Default: not set (will skip download if files exist)
FORCE_DOWNLOAD=

# Use API Method for Download (Optional)
# Set to "true" to use Hugging Face Datasets Server API instead of snapshot download
# API method streams data directly and may be more efficient for large datasets
# Default: not set (uses snapshot download method)
USE_API=

# AnswerAgent API Configuration (Optional)
# Base URL for the AnswerAgent API
# Default: https://api.answeragent.com
ANSWERAGENT_API_URL=https://api.answeragent.com

# AnswerAgent API Key (Required for AnswerAgent integration)
# Get your API key from your AnswerAgent account
ANSWERAGENT_API_KEY=your_answeragent_api_key_here

# uDb (Larry Hatch UFO Database) Configuration (Optional)
# Path to the U.RND database file for the uDb integration
# Default: ./input/db/udb/data/U.RND
# The @rr0/udb package includes a sample database at: node_modules/@rr0/udb/data/udb/input/U.RND
# You can download the database from: https://github.com/RR0/uDb
# Note: The database file is large and should not be committed to git
UDB_DATABASE_PATH=./input/db/udb/data/U.RND

# Supabase Local Configuration (Optional)
# These variables are automatically generated by running: npm run setup-supabase
# Supabase API URL (local instance)
SUPABASE_URL=http://localhost:8000

# Supabase Anonymous Key (public, safe to expose in client-side code)
# This is used for server-side operations and can fall back to NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (private, server-side only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Next.js Public Supabase Configuration (Required for SSR)
# These variables are exposed to the browser and used by the SSR client
# NEXT_PUBLIC_ variables are required for proper SSR support in Next.js 16
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Database Configuration (Optional - for direct database access)
# These are generated during setup and stored in .env.local
# POSTGRES_PASSWORD= (generated during setup)
# JWT_SECRET= (generated during setup)
# JWT_EXPIRY=3600
# ANON_KEY= (generated during setup)
# SERVICE_ROLE_KEY= (generated during setup)
# SITE_URL=http://localhost:3000
# URI_ALLOW_LIST=http://localhost:3000,http://localhost:3001
# DISABLE_SIGNUP=false
# ENABLE_EMAIL_SIGNUP=true
# ENABLE_EMAIL_AUTOCONFIRM=true
# IMGPROXY_ENABLE_WEBP_DETECTION=true
# SECRET_KEY_BASE= (optional, for Realtime service - defaults to a placeholder if not set)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI API Configuration (Required for Whisper transcription and PDF extraction)
# Get your API key from: https://platform.openai.com/api-keys
# Required for:
#   - Audio transcription feature (Whisper service)
#   - PDF text extraction (OpenAI service option)
# The API key is used server-side only and should never be exposed to the client
OPENAI_API_KEY=your_openai_api_key_here

# Assembly AI API Configuration (Optional - for Assembly AI transcription)
# Get your API key from: https://www.assemblyai.com/app/account
# Required for audio transcription feature (Assembly AI service)
# The API key is used server-side only and should never be exposed to the client
# Assembly AI offers advanced features like speaker diarization and sentiment analysis
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
