# Environment Variables Template
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local or any file containing actual credentials

# Hugging Face API Token (Optional)
# Get your token at: https://huggingface.co/settings/tokens
# - Create a "Read" token (not Write)
# - Required for snapshot download method
# - NOT required for API method (USE_API=true) with public datasets
# - Token permissions: Read access to datasets
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Force Dataset Download (Optional)
# Set to "true" to force re-download of the dataset even if files exist
# Default: not set (will skip download if files exist)
FORCE_DOWNLOAD=

# Use API Method for Download (Optional)
# Set to "true" to use Hugging Face Datasets Server API instead of snapshot download
# API method streams data directly and may be more efficient for large datasets
# Default: not set (uses snapshot download method)
USE_API=

# AnswerAgent API Configuration (Optional)
# Base URL for the AnswerAgent API
# Default: https://api.answeragent.com
ANSWERAGENT_API_URL=https://api.answeragent.com

# AnswerAgent API Key (Required for AnswerAgent integration)
# Get your API key from your AnswerAgent account
ANSWERAGENT_API_KEY=your_answeragent_api_key_here

# uDb (Larry Hatch UFO Database) Configuration (Optional)
# Path to the U.RND database file for the uDb integration
# Default: ./input/db/udb/data/U.RND
# The @rr0/udb package includes a sample database at: node_modules/@rr0/udb/data/udb/input/U.RND
# You can download the database from: https://github.com/RR0/uDb
# Note: The database file is large and should not be committed to git
UDB_DATABASE_PATH=./input/db/udb/data/U.RND

# Supabase Local Configuration (Optional)
# These variables are automatically generated by running: npm run setup-supabase
# Supabase API URL (local instance)
SUPABASE_URL=http://localhost:8000

# Supabase Anonymous Key (public, safe to expose in client-side code)
# This is used for server-side operations and can fall back to NEXT_PUBLIC_SUPABASE_ANON_KEY
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (private, server-side only - keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Next.js Public Supabase Configuration (Required for SSR)
# These variables are exposed to the browser and used by the SSR client
# NEXT_PUBLIC_ variables are required for proper SSR support in Next.js 16
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Database Configuration (Optional - for direct database access)
# These are generated during setup and stored in .env.local
# POSTGRES_PASSWORD= (generated during setup)
# JWT_SECRET= (generated during setup)
# JWT_EXPIRY=3600
# ANON_KEY= (generated during setup)
# SERVICE_ROLE_KEY= (generated during setup)
# SITE_URL=http://localhost:3000
# URI_ALLOW_LIST=http://localhost:3000,http://localhost:3001
# DISABLE_SIGNUP=false
# ENABLE_EMAIL_SIGNUP=true
# ENABLE_EMAIL_AUTOCONFIRM=true
# IMGPROXY_ENABLE_WEBP_DETECTION=true
# SECRET_KEY_BASE= (optional, for Realtime service - defaults to a placeholder if not set)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# LLM Provider Configuration
# Options: "openai" or "ollama"
# Default: "openai"
# When set to "ollama", uses local LLM models (requires Ollama to be running)
# When set to "openai", uses OpenAI API (requires OPENAI_API_KEY)
LLM_PROVIDER=openai

# OpenAI API Configuration (Required when LLM_PROVIDER=openai)
# Get your API key from: https://platform.openai.com/api-keys
# Required for:
#   - Audio transcription feature (Whisper service)
#   - PDF text extraction (OpenAI service option)
#   - Entity extraction, description generation, relationship extraction (when LLM_PROVIDER=openai)
# The API key is used server-side only and should never be exposed to the client
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (Optional)
# Custom base URL for OpenAI API (e.g., for proxy or custom endpoints)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=

# Ollama Configuration (Required when LLM_PROVIDER=ollama)
# Base URL for Ollama API
# Default: http://localhost:11434
# Install Ollama from: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Default Model (Optional)
# Default model to use when LLM_PROVIDER=ollama
# Recommended models:
#   - llama3.1:8b (default) - Best balance: excellent JSON, good performance, reasonable RAM (~5GB)
#   - nemotron-3-nano:30b - NVIDIA's latest agentic model, excellent reasoning, requires ~20GB RAM
#   - llama3.1:70b - More capable but requires ~40GB RAM
#   - qwen2.5:7b - Great for long context (128K tokens), multilingual
#   - mistral - Well-tested 7B model
#   - llama3.2:3b - Smaller, faster, good for lower-end hardware
# Default: llama3.1:8b
# See app/lib/llm/MODEL_COMPARISON.md for detailed comparison
# Run "ollama list" to see available models
# Run "ollama pull <model>" to download a model
OLLAMA_DEFAULT_MODEL=llama3.1:8b

# Assembly AI API Configuration (Optional - for Assembly AI transcription)
# Get your API key from: https://www.assemblyai.com/app/account
# Required for audio transcription feature (Assembly AI service)
# The API key is used server-side only and should never be exposed to the client
# Assembly AI offers advanced features like speaker diarization and sentiment analysis
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Neo4j Configuration (Required for graph database features)
# Neo4j connection URI (Bolt protocol)
# Default: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687

# Neo4j username
# Default: neo4j
NEO4J_USER=neo4j

# Neo4j password
# IMPORTANT: Set a secure password for Neo4j
# Default in docker-compose: password123 (for development only - CHANGE THIS!)
# For production, use a strong password
# Note: Password cannot contain "neo4j" as a substring
# The password is set via NEO4J_AUTH in docker-compose.yml
NEO4J_PASSWORD=password123

# Neo4j database name
# Default: neo4j
NEO4J_DATABASE=neo4j

# Neo4j encryption (Optional)
# Set to "false" to disable encryption for local development
# Set to "true" to enable encryption (default for remote connections)
# If not set, automatically disables for localhost connections
NEO4J_ENCRYPTED=

# Hugging Face API Key (Optional - for NER entity extraction)
# Get your token at: https://huggingface.co/settings/tokens
# Required for Named Entity Recognition (NER) baseline extraction
# If not provided, falls back to pattern-based extraction
# Token permissions: Read access to models
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Feature Flags

# Enable automatic entity extraction when processing PDFs/audio/video/scrape
# When enabled, entities are automatically extracted after text extraction completes
# Default: false (set to "true" to enable)
ENABLE_AUTO_ENTITY_EXTRACTION=false

# Enable Neo4j synchronization
# When enabled, entities and relationships are automatically synced to Neo4j
# Default: false (set to "true" to enable)
ENABLE_NEO4J_SYNC=false

# NER Provider
# Options: 
#   - "huggingface" (uses Hugging Face Inference API - requires HUGGINGFACE_API_KEY and may incur costs)
#   - "local" (uses @xenova/transformers - runs locally, no API costs, but requires model download on first use)
# Default: "huggingface"
# Note: When using "local", models are downloaded and cached locally on first use (~400MB for bert-base-NER)
NER_PROVIDER=huggingface
